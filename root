<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Mr Right</title>

  <!-- Google Font -->
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;600&display=swap" rel="stylesheet">

  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }

    body {
      font-family: 'Poppins', sans-serif;
      background: #0b0f1a;
      color: #fff;
      scroll-behavior: smooth;
    }

    /* HEADER */
    header {
      position: fixed;
      width: 100%;
      top: 0;
      left: 0;
      background: rgba(0,0,0,0.7);
      backdrop-filter: blur(10px);
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 15px 40px;
      z-index: 1000;
    }

    header h1 {
      font-size: 22px;
      color: #00eaff;
    }

    nav a {
      margin-left: 20px;
      text-decoration: none;
      color: #ccc;
      transition: 0.3s;
    }

    nav a:hover {
      color: #00eaff;
    }

    /* HERO */
    .hero {
      height: 100vh;
      display: flex;
      flex-direction: column;
      justify-content: center;
      align-items: center;
      text-align: center;
      background: radial-gradient(circle at center, #0f172a, #020617);
    }

    .hero h1 {
      font-size: 60px;
      margin-bottom: 10px;
    }

    .hero p {
      color: #aaa;
      margin-bottom: 20px;
    }

    .btn {
      padding: 12px 28px;
      border-radius: 30px;
      border: none;
      background: linear-gradient(90deg, #00eaff, #0077ff);
      color: white;
      cursor: pointer;
      transition: 0.3s;
    }

    .btn:hover {
      transform: scale(1.05);
    }

    /* SECTIONS */
    section {
      padding: 80px 20px;
      text-align: center;
    }

    h2 {
      margin-bottom: 30px;
      font-size: 32px;
    }

    /* SERVICES */
    .services {
      display: flex;
      justify-content: center;
      flex-wrap: wrap;
    }

    .card {
      background: #111827;
      margin: 15px;
      padding: 25px;
      width: 260px;
      border-radius: 15px;
      transition: 0.3s;
    }

    .card:hover {
      transform: translateY(-10px);
      box-shadow: 0 10px 30px rgba(0,234,255,0.2);
    }

    /* ABOUT */
    .about p {
      max-width: 600px;
      margin: auto;
      color: #aaa;
    }

    /* CONTACT */
    .contact input, .contact textarea {
      width: 80%;
      padding: 12px;
      margin: 10px;
      border-radius: 8px;
      border: none;
      background: #1f2937;
      color: white;
    }

    /* FOOTER */
    footer {
      background: #020617;
      padding: 20px;
      text-align: center;
      color: #777;
    }

    /* RESPONSIVE */
    @media(max-width: 768px) {
      .hero h1 { font-size: 40px; }
      header { padding: 15px 20px; }
    }
  </style>
</head>
<body>

<header>
  <h1>Mr Right</h1>
  <nav>
    <a href="#home">Home</a>
    <a href="#services">Services</a>
    <a href="#about">About</a>
    <a href="#contact">Contact</a>
  </nav>
</header>

<!-- HERO -->
<section id="home" class="hero">
  <h1>Mr Right</h1>
  <p>Your Perfect Tech Partner 🚀</p>
  <button class="btn">Get Started</button>
</section>

<!-- SERVICES -->
<section id="services">
  <h2>Our Services</h2>
  <div class="services">
    <div class="card">Web Development</div>
    <div class="card">AI Solutions</div>
    <div class="card">Embedded Systems</div>
  </div>
</section>

<!-- ABOUT -->
<section id="about" class="about">
  <h2>About Us</h2>
  <p>Mr Right delivers cutting-edge solutions in AI, embedded systems, and modern web technologies. We help businesses and individuals build smart, scalable, and future-ready systems.</p>
</section>

<!-- CONTACT -->
<section id="contact" class="contact">
  <h2>Contact Us</h2>
  <input type="text" placeholder="Your Name"><br>
  <input type="email" placeholder="Your Email"><br>
  <textarea rows="4" placeholder="Your Message"></textarea><br>
  <button class="btn">Send Message</button>
</section>

<footer>
  <p>© 2026 Mr Right | Designed with ⚡</p>
</footer>

</body>
</html>
